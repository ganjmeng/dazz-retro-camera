{
  "id": "polaroid_classic",
  "name": "Polaroid Classic",
  "category": "instant",
  "outputType": "photo",
  "isPremium": true,
  "thumbnail": "thumbnails/polaroid_classic.png",
  "baseModel": {
    "sensor": { "type": "instant" },
    "color": { "contrast": 0.90, "saturation": 0.95 }
  },
  "optionGroups": {
    "films": [
      {
        "id": "polaroid_default",
        "name": "Classic",
        "isDefault": true,
        "rendering": {
          "lut": "lut/instant_polaroid.cube",
          "grain": "grain/grain_fine.png",
          "grainIntensity": 0.12,
          "temperatureShift": 80.0,
          "chromaticAberration": 0.005,
          "vignetteAmount": 0.12
        }
      }
    ],
    "lenses": [
      {
        "id": "soft_lens",
        "name": "Soft Lens",
        "isDefault": true,
        "rendering": {
          "bloom": 0.15,
          "vignette": 0.10,
          "blurRadius": 0.8
        }
      },
      {
        "id": "wide_lens",
        "name": "Wide Lens",
        "isDefault": false,
        "rendering": {
          "bloom": 0.05,
          "vignette": 0.18,
          "distortion": 0.03
        }
      }
    ],
    "papers": [
      {
        "id": "white_border",
        "name": "White Border",
        "isDefault": true,
        "rendering": {
          "frame": "frames/polaroid_white_frame.png",
          "frameScale": 1.0
        }
      },
      {
        "id": "cream_border",
        "name": "Cream Border",
        "isDefault": false,
        "rendering": {
          "frame": "frames/polaroid_cream_frame.png",
          "frameScale": 1.0
        }
      }
    ],
    "ratios": [
      { "id": "ratio_1_1", "name": "1:1", "value": "1:1", "isDefault": true }
    ],
    "watermarks": [
      {
        "id": "instant_footer",
        "name": "Footer Mark",
        "isDefault": true,
        "type": "frame_text",
        "rendering": {
          "textFormat": "POLAROID",
          "position": "frame_bottom",
          "opacity": 0.85
        }
      },
      {
        "id": "none",
        "name": "None",
        "isDefault": false,
        "type": "none"
      }
    ]
  },
  "uiCapabilities": {
    "showFilmSelector": true,
    "showLensSelector": true,
    "showPaperSelector": true,
    "showRatioSelector": false,
    "showWatermarkSelector": true
  }
}
