{
  "id": "polaroid_classic",
  "name": "Polaroid Classic",
  "category": "instant",
  "outputType": "instant",
  "isPremium": false,
  "thumbnail": "thumbnails/polaroid_classic.png",
  "baseModel": {
    "sensor": {
      "type": "instant_sim",
      "dynamic_range": 6.5,
      "noise": 0.12
    },
    "color": {
      "temperature": 80,
      "contrast": 0.92,
      "saturation": 0.94,
      "brightness": 0.03
    },
    "highlight": {
      "halation": 0.12,
      "rolloff": 0.25
    }
  },
  "optionGroups": {
    "films": [
      {
        "id": "instant_classic",
        "name": "Classic",
        "isDefault": true,
        "rendering": {
          "lut": "lut/instant_polaroid.cube",
          "grain": "grain/grain_fine.png",
          "grainIntensity": 0.10,
          "temperatureShift": 80.0,
          "chromaticAberration": 0.005,
          "vignetteAmount": 0.08,
          "fadeAmount": 0.05
        }
      },
      {
        "id": "instant_fade",
        "name": "Faded",
        "isDefault": false,
        "rendering": {
          "lut": "lut/instant_polaroid.cube",
          "grain": "grain/grain_fine.png",
          "grainIntensity": 0.12,
          "temperatureShift": 120.0,
          "chromaticAberration": 0.008,
          "vignetteAmount": 0.10,
          "fadeAmount": 0.18
        }
      }
    ],
    "lenses": [
      {
        "id": "soft_lens",
        "name": "Soft",
        "isDefault": true,
        "rendering": {
          "vignette": 0.10,
          "bloom": 0.12,
          "blurRadius": 0.5
        }
      },
      {
        "id": "sharp_lens",
        "name": "Sharp",
        "isDefault": false,
        "rendering": {
          "vignette": 0.15,
          "bloom": 0.04,
          "blurRadius": 0.0
        }
      }
    ],
    "papers": [
      {
        "id": "polaroid_white",
        "name": "White",
        "isDefault": true,
        "rendering": {
          "frameAsset": "frames/polaroid_white_frame.png",
          "backgroundColor": "#FFFFFF",
          "marginTop": 0.04,
          "marginBottom": 0.22,
          "marginLeft": 0.04,
          "marginRight": 0.04
        }
      },
      {
        "id": "polaroid_cream",
        "name": "Cream",
        "isDefault": false,
        "rendering": {
          "frameAsset": "frames/polaroid_cream_frame.png",
          "backgroundColor": "#F5F0E8",
          "marginTop": 0.04,
          "marginBottom": 0.22,
          "marginLeft": 0.04,
          "marginRight": 0.04
        }
      }
    ],
    "ratios": [
      { "id": "ratio_1_1", "name": "1:1", "value": "1:1", "isDefault": true }
    ],
    "watermarks": [
      {
        "id": "instant_footer",
        "name": "Footer",
        "type": "frame_text",
        "isDefault": true,
        "rendering": {
          "textFormat": "POLAROID",
          "position": "frame_bottom",
          "color": "#888888",
          "opacity": 0.70,
          "fontSize": 10.0,
          "renderLayer": "frame"
        }
      },
      {
        "id": "instant_date",
        "name": "Date",
        "type": "digital_date",
        "isDefault": false,
        "rendering": {
          "position": "frame_bottom",
          "color": "#888888",
          "opacity": 0.70,
          "fontSize": 10.0,
          "renderLayer": "frame"
        }
      },
      {
        "id": "none",
        "name": "None",
        "type": "none",
        "isDefault": false,
        "rendering": {}
      }
    ]
