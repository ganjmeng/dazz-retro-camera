{
  "id": "vhs_cam",
  "name": "VHS Camcorder",
  "category": "video",
  "outputType": "video",
  "isPremium": true,
  "thumbnail": "thumbnails/vhs_camcorder.png",
  "baseModel": {
    "scan": {
      "scanlines": 0.18,
      "interlace": true,
      "resolution": "480p"
    },
    "color": { "saturation": 0.85, "contrast": 1.05 },
    "noise": { "luminance": 0.20, "chroma": 0.15 }
  },
  "optionGroups": {
    "ratios": [
      { "id": "ratio_4_3", "name": "4:3", "value": "4:3", "isDefault": true }
    ],
    "watermarks": [
      {
        "id": "rec_overlay",
        "name": "REC Marker",
        "isDefault": true,
        "type": "video_rec",
        "rendering": {
          "asset": "watermarks/rec_overlay.png",
          "position": "top_left",
          "opacity": 0.90,
          "blinkInterval": 1000
        }
      },
      {
        "id": "rec_with_date",
        "name": "REC + Date",
        "isDefault": false,
        "type": "video_rec_date",
        "rendering": {
          "asset": "watermarks/rec_overlay.png",
          "dateAsset": "watermarks/date_stamp_orange.png",
          "position": "top_left",
          "opacity": 0.90,
          "blinkInterval": 1000
        }
      }
    ]
  },
  "uiCapabilities": {
    "showFilmSelector": false,
    "showLensSelector": false,
    "showPaperSelector": false,
    "showRatioSelector": true,
    "showWatermarkSelector": true
  }
}
