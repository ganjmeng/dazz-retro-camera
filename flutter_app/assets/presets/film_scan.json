{
  "id": "film_scan",
  "name": "Film Scan",
  "category": "scanner",
  "outputType": "photo",
  "isPremium": false,
  "thumbnail": "thumbnails/film_scan.png",
  "baseModel": {
    "sensor": { "type": "scanner", "dust": 0.05 },
    "color": { "contrast": 1.0, "saturation": 0.92 }
  },
  "optionGroups": {
    "films": [
      {
        "id": "scan_clean",
        "name": "Clean Scan",
        "isDefault": true,
        "rendering": {
          "lut": "lut/film_scan.cube",
          "grain": "grain/grain_fine.png",
          "grainIntensity": 0.15,
          "temperatureShift": 0.0,
          "chromaticAberration": 0.003,
          "vignetteAmount": 0.10,
          "dustAmount": 0.0
        }
      },
      {
        "id": "scan_dust",
        "name": "Dusty Scan",
        "isDefault": false,
        "rendering": {
          "lut": "lut/film_scan.cube",
          "grain": "grain/grain_coarse.png",
          "grainIntensity": 0.28,
          "temperatureShift": -50.0,
          "chromaticAberration": 0.008,
          "vignetteAmount": 0.22,
          "dustAmount": 0.15
        }
      }
    ],
    "ratios": [
      { "id": "ratio_3_2", "name": "3:2", "value": "3:2", "isDefault": true },
      { "id": "ratio_1_1", "name": "1:1", "value": "1:1", "isDefault": false }
    ]
  },
  "uiCapabilities": {
    "showFilmSelector": true,
    "showLensSelector": false,
    "showPaperSelector": false,
    "showRatioSelector": true,
    "showWatermarkSelector": false
  }
}
